#!/bin/zsh

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

source "$PROJECT_ROOT/lib/core.sh"

COMMAND="${1:-}"

case "$COMMAND" in
  new)
    shift
    source "$PROJECT_ROOT/lib/commands/new.sh"
    cal_new "$@"
    ;;

  help|-h|--help|"")
    cal_show_help
    ;;

  *)
    echo "Error: unknown command: $COMMAND"
    echo
    cal_show_help
    exit 1
    ;;
esac
